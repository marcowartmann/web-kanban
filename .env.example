# Root docker-compose configuration. Copy to .env to override.
POSTGRES_USER=kanban
POSTGRES_PASSWORD=kanban
POSTGRES_DB=kanban

# Host ports (container ports are fixed: frontend 80/443, backend 8000).
APP_PORT=8080
HTTPS_PORT=8443
BACKEND_PORT=8000

# Backup encryption key (encrypts the stored SFTP password). Change in production.
APP_SECRET=dev-insecure-change-me
# Dev SFTP backup target (atmoz/sftp)
SFTP_USER=kanban
SFTP_PASSWORD=kanban
SFTP_PORT=2222

# Postgres is published for external clients (psql/DBeaver/pgAdmin).
# DB_BIND controls reachability: 127.0.0.1 = this host only (default),
# 0.0.0.0 = any network interface (LAN — use a strong POSTGRES_PASSWORD).
DB_BIND=127.0.0.1
DB_PORT=5432

# --- LDAP authentication (optional; off by default) ---
# Defaults below are for OpenLDAP. For Active Directory, see the AD block after.
LDAP_ENABLED=false
LDAP_SERVER_URI=ldaps://ldap.internal:636
LDAP_START_TLS=false
LDAP_CA_CERT_FILE=
LDAP_BIND_DN=cn=reader,dc=example,dc=com
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=ou=people,dc=example,dc=com
LDAP_USER_FILTER=(&(objectClass=inetOrgPerson)(uid={uid}))
LDAP_ATTR_EMAIL=mail
LDAP_ATTR_DISPLAY_NAME=cn

# --- Active Directory example (uncomment/adapt; overrides the OpenLDAP block) ---
# Users log in with their sAMAccountName. objectCategory=person excludes computer
# accounts. Referral chasing is disabled in code, which AD requires.
# LDAP_SERVER_URI=ldaps://dc1.corp.example.com:636
# LDAP_START_TLS=false
# LDAP_CA_CERT_FILE=/certs/corp-ca.pem
# LDAP_BIND_DN=svc-jamra@corp.example.com
# LDAP_BIND_PASSWORD=<service account password>
# LDAP_BASE_DN=DC=corp,DC=example,DC=com
# LDAP_USER_FILTER=(&(objectCategory=person)(objectClass=user)(sAMAccountName={uid}))
# LDAP_ATTR_EMAIL=mail
# LDAP_ATTR_DISPLAY_NAME=displayName

INITIAL_ADMIN_USERNAME=admin
