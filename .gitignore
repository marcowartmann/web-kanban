# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/

# Node
node_modules/
dist/
.vite/
*.tsbuildinfo

# Env / secrets
.env
.env.*
!.env.example
!.env.prod.example

# OS / editor
.DS_Store
.idea/
.vscode/

# Playwright MCP artifacts
.playwright-mcp/

# Local agent definitions (not part of the app)
.github/agents/

# FontAwesome Pro token (local only — never commit)
.fa-token
frontend/.fa-token

# SFTP backup artifacts (bind-mounted target)
sftp/uploads/*
!sftp/uploads/.gitkeep

# nginx TLS cert/key (bind-mounted; never commit real or dev keys)
nginx/certs/*
!nginx/certs/.gitkeep

# Database dumps (may contain user password hashes — never commit)
*.sql.gz
