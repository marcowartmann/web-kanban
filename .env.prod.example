# Production configuration for docker-compose.prod.yml. Copy to .env and fill in
# real secrets. Values marked REQUIRED have no safe default — compose refuses to
# start until they are set.

# Image tag to deploy (must match what scripts/publish.sh pushed).
IMAGE_TAG=latest

# Host ports the frontend listens on (container ports are fixed: 80 + 443).
APP_PORT=80
HTTPS_PORT=443

# --- Database ---
POSTGRES_USER=kanban
POSTGRES_PASSWORD=            # REQUIRED — use a long random value
POSTGRES_DB=kanban

# --- Security ---
# REQUIRED — encrypts the stored SFTP backup password. Keep stable; rotating it
# invalidates any saved backup password. Generate e.g. `openssl rand -hex 32`.
APP_SECRET=
# Session cookie is HTTPS-only in production. Only set false if not behind TLS.
COOKIE_SECURE=true

# --- Initial admin (created on first start) ---
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_PASSWORD=        # REQUIRED — change immediately after first login

# --- LDAP authentication (optional; off by default) ---
LDAP_ENABLED=false
LDAP_SERVER_URI=ldaps://ldap.internal:636
LDAP_START_TLS=false
LDAP_CA_CERT_FILE=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=ou=people,dc=example,dc=com
LDAP_USER_FILTER=(&(objectClass=inetOrgPerson)(uid={uid}))
LDAP_ATTR_EMAIL=mail
LDAP_ATTR_DISPLAY_NAME=cn
