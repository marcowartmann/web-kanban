# FontAwesome Pro registry. The token is NOT stored here — it is read from the
# FONTAWESOME_PACKAGE_TOKEN environment variable (local dev) or a Docker build
# secret of the same name. Never commit the literal token.
@fortawesome:registry=https://npm.fontawesome.com/
@awesome.me:registry=https://npm.fontawesome.com/
//npm.fontawesome.com/:_authToken=${FONTAWESOME_PACKAGE_TOKEN}
